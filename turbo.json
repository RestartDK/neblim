{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "PORT",
    "VITE_API_BASE_URL",
    "VITE_WS_BASE_URL",
    "VITE_POSE3D_API_BASE_URL",
    "VITE_POSE3D_WS_BASE_URL",
    "VITE_AI_SERVER_BASE_URL",
    "WIFI_DENSEPOSE_BIND_ADDR",
    "WIFI_DENSEPOSE_ALLOWED_ORIGINS",
    "WIFI_DENSEPOSE_PRESENCE_TTL_MS",
    "WIFI_DENSEPOSE_POSE_FRAME_TICK_MS",
    "WIFI_DENSEPOSE_ESP32_PORT",
    "WIFI_DENSEPOSE_ESP32_BAUD_RATE",
    "WIFI_DENSEPOSE_ESP32_READ_TIMEOUT_MS",
    "WIFI_DENSEPOSE_MOTION_ACTIVE_THRESHOLD",
    "WIFI_DENSEPOSE_MOTION_HIGH_THRESHOLD",
    "RUST_LOG"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
