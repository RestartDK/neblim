{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "PORT",
    "VITE_API_BASE_URL",
    "VITE_WS_BASE_URL",
    "VITE_POSE3D_API_BASE_URL",
    "VITE_POSE3D_WS_BASE_URL",
    "POSE_BRIDGE_SERIAL_PORT",
    "POSE_BRIDGE_BAUD_RATE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
