# Logging
RUST_LOG=info

# Optional: override bind address (default: 127.0.0.1:8787)
# WIFI_DENSEPOSE_BIND_ADDR=127.0.0.1:8787

# Optional: include your local frontend dev origins
# WIFI_DENSEPOSE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Optional: ESP32 CSI ingestion
# Set this to your serial device to enable presence packets/logs
# WIFI_DENSEPOSE_ESP32_PORT=/dev/cu.usbserial-0001
# WIFI_DENSEPOSE_ESP32_BAUD_RATE=921600
# WIFI_DENSEPOSE_ESP32_READ_TIMEOUT_MS=25

# Optional: presence behavior
# WIFI_DENSEPOSE_PRESENCE_TTL_MS=1500
# WIFI_DENSEPOSE_POSE_FRAME_TICK_MS=250
